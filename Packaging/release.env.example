# Copy this file to something like Packaging/release.env and source it before packaging.

export BUNDLE_ID="com.loqbar.app"
export MARKETING_VERSION="0.1.0"
export BUILD_NUMBER="1"

# Real distribution signing identity:
# export SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# A notarytool keychain profile created with:
# xcrun notarytool store-credentials "LoqBarNotary" --apple-id ... --team-id ... --password ...
# export KEYCHAIN_PROFILE="LoqBarNotary"
